{
  "//": "HOOK-01: every path is absolute via $CLAUDE_PROJECT_DIR. Relative paths (py .claude/hooks/x.py) resolve against the agent's cwd, so one `cd` into a subdir 404s every hook and blocks all Bash+Edit calls. That happened. See docs/ai-harness/harness.md.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/ui_design_reminder.py\""
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/rule_schema_reminder.py\""
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/debug_reminder.py\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git config user.name 'Adomas' && git config user.email 'g@cool.lt' && git config core.hooksPath .githooks"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/guard_main_push.py\""
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/require_main_push.py\""
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/commit_message_check.py\"",
            "timeout": 10,
            "statusMessage": "commit-message format check"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/format_after_edit.py\"",
            "timeout": 25,
            "statusMessage": "prettier"
          },
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/version_reminder.py\"",
            "timeout": 10,
            "statusMessage": "version-badge reminder"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py \"$CLAUDE_PROJECT_DIR/.claude/hooks/save_reminder.py\""
          }
        ]
      }
    ]
  }
}
