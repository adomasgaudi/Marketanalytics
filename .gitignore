# VS Code multi-root workspace (local, references sibling ../Data repo)
*.code-workspace

# Knowledge graph — regenerated by the graphify skill, never hand-edited.
graphify-out/

# Scraper intermediates — multi-MB raw HTML per tab, reproducible via scrape_6_vijos.py
6_vijos_raw.html
data/raw/

# Python bytecode cache
__pycache__/
*.pyc

# Persistent Chrome profile for the rekvizitai scraper (holds the CF clearance cookie)
data/.pwprofile/

# --- Next.js app (hoisted from next-app/) ---

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
